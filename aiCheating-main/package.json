{
  "name": "ai-cheating",
  "version": "1.0.0",
  "main": "Electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "electron .",
    "build": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.kartik.AiCheating",
    "productName": "AiCheating",
    "files": [
      "Electron/**/*",
      "dist/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "Electron/assets"
    },
    "icon": "Electron/assets/icon"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^6.4.3",
    "@vitejs/plugin-react": "^4.3.1"
  }
}
